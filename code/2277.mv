# 2277 - if else: read two chars, output 1 if equal else 0
# Initialize lookup table
A<48
B<256
[B]<A
A<49
[B+49]<A
# Read first char
C<I
# Set mem[256+C] = 49 ('1')
A<49
[B+C]<A
# Read second char
D<I
# Get result: mem[256+D]
E<[B+D]
# If E == 0, output 48. If E == 49, output 49.
# Use mem[256] = 48, mem[305] = 49
O<[B+E]
Z<1
